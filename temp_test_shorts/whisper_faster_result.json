    },
    {
      "index": 2,
      "start_sec": 13.2,
      "end_sec": 23.2,
      "text": "Me avisa aí, já diminuíta, me avisa aí, fica muito alto por acaso."
    },
    {
      "index": 3,
      "start_sec": 23.2,
      "end_sec": 27.92,
      "text": "Boa tarde, vamos chegando, vamos chegando."
    },
    {
      "index": 4,
      "start_sec": 27.92,
      "end_sec": 31.92,
      "text": "Não se aca, hein?"
    },
    {
      "index": 5,
      "start_sec": 31.92,
