    {
      "index": 17,
      "start_sec": 96.92,
      "end_sec": 98.92,
      "text": "Acho que nem começou a chover ainda."
    },
    {
      "index": 18,
      "start_sec": 98.92,
      "end_sec": 100.92,
      "text": "Acho que um calor que tá fazendo."
    },
    {
      "index": 19,
      "start_sec": 100.92,
      "end_sec": 104.92,
      "text": "Eu achei até que eu pudesse ficar sem luz, né?"
    },
    {
      "index": 20,
      "start_sec": 104.92,
      "end_sec": 109.92,
      "text": "Mas se isso acontecesse, eu ia mandar mensagem para avisar a produção."
    },
    {
      "index": 21,
      "start_sec": 109.92,
      "end_sec": 111.92,
      "text": "Boa tarde, Adriano."
    },
    {
      "index": 22,
      "start_sec": 111.92,
      "end_sec": 117.92,
      "text": "Tudo em piscis?"
    },
    {
      "index": 23,
      "start_sec": 117.92,
      "end_sec": 121.92,
      "text": "Iaiaa!"
    },
    {
      "index": 24,
      "start_sec": 121.92,
      "end_sec": 125.92,
      "text": "Bom, antes de começar aqui com a nossa Jinx,"
