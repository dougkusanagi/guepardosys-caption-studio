    {
      "index": 28,
      "start_sec": 137.92,
      "end_sec": 139.92,
      "text": "Ó..."
    },
    {
      "index": 29,
      "start_sec": 151.92,
      "end_sec": 155.92,
      "text": "Então, recadinhos. Primeiro, promoção de cursos e planos de assinatura."
    },
    {
      "index": 30,
      "start_sec": 155.92,
      "end_sec": 163.92,
      "text": "Então, curso-avulso de R$ 398 por 10 vezes de R$ 23,88, 100 juros, tá bom?"
    },
    {
      "index": 31,
      "start_sec": 163.92,
      "end_sec": 167.92,
      "text": "Ou R$ 238 a vista, acesso vitalício, né, nesse caso."
    },
    {
      "index": 32,
      "start_sec": 167.92,
      "end_sec": 175.92,
      "text": "Plano mensal, e cansa-lhe quando quiser, de R$ 148 por R$ 163 no primeiro mês,"
    },
    {
      "index": 33,
      "start_sec": 175.92,
      "end_sec": 177.92,
      "text": "meses seguintes, R$ 148."
    },
    {
      "index": 34,
      "start_sec": 177.92,
      "end_sec": 183.92,
      "text": "Plana anual, confidelidade, 12 meses de R$ 99 por R$ 69,30 no primeiro mês,"
    },
    {
      "index": 35,
      "start_sec": 183.92,
      "end_sec": 187.92,
      "text": "e os meses seguintes a R$ 99 por mês, tá bom?"
    },
    {
      "index": 36,
      "start_sec": 187.92,
      "end_sec": 191.92,
      "text": "E, segundo recadinho, então, pesquisa com o público do Discord."
    },
    {
      "index": 37,
      "start_sec": 191.92,
      "end_sec": 195.92,
      "text": "E se você é do Discord, o nosso Discord, né, da Dunhyde,"
