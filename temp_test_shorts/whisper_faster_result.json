  "segments": [
    {
      "index": 0,
      "start_sec": 0.0,
      "end_sec": 9.0,
      "text": "Cheguei atrasado, tá só hoje, tudo bem?"
    },
    {
      "index": 1,
      "start_sec": 9.0,
