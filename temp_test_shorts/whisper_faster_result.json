    {
      "index": 25,
      "start_sec": 125.92,
      "end_sec": 129.92,
      "text": "vou trazer os recadinhos da semana rapidinho."
    },
    {
      "index": 26,
      "start_sec": 129.92,
      "end_sec": 135.92,
      "text": "Então, ó, deixa você trago aqui na chapaerta."
