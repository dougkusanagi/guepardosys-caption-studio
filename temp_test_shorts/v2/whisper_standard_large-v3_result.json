      "text": "E aí com o chá"
    },
    {
      "index": 148,
      "start_sec": 391.46,
      "end_sec": 393.46,
      "text": "Já agora na quarta semana"
    },
    {
      "index": 149,
      "start_sec": 393.46,
      "end_sec": 395.46,
      "text": "É..."
    },
    {
      "index": 150,
      "start_sec": 395.46,
      "end_sec": 397.46,
      "text": "Primeiro que a ansiedade diminuiu muito"
