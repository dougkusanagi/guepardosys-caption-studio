    {
      "index": 136,
      "start_sec": 538.0,
      "end_sec": 540.0,
      "text": "a anatomia do ensaio,"
    },
    {
      "index": 137,
      "start_sec": 540.0,
      "end_sec": 542.0,
      "text": "a anatomia do ensaio,"
    },
    {
      "index": 138,
      "start_sec": 543.0,
      "end_sec": 544.0,
      "text": "a anatomia dos ensaios,"
    },
    {
      "index": 139,
      "start_sec": 544.0,
      "end_sec": 548.0,
      "text": "é mais ou menos um coração invertido."
    },
    {
      "index": 140,
      "start_sec": 551.0,
      "end_sec": 553.0,
      "text": "Vou explicar o que eu quero dizer com isso."
    },
    {
      "index": 141,
      "start_sec": 556.0,
      "end_sec": 558.0,
      "text": "A gente pode fazer tipo..."
    },
    {
      "index": 142,
      "start_sec": 560.0,
      "end_sec": 561.0,
      "text": "É tipo..."
    },
    {
      "index": 143,
      "start_sec": 561.0,
      "end_sec": 563.0,
      "text": "Nossa!"
    },
    {
      "index": 144,
      "start_sec": 563.0,
      "end_sec": 565.0,
      "text": "Deixa eu ver se eu consigo desenhar."
    },
    {
      "index": 145,
      "start_sec": 566.0,
      "end_sec": 569.0,
      "text": "Acho que está dando para ter a ideia, né?"
    },
    {
      "index": 146,
      "start_sec": 569.0,
      "end_sec": 571.0,
      "text": "Um coração."
    },
    {
      "index": 147,
      "start_sec": 571.0,
      "end_sec": 573.0,
      "text": "Um coração invertido."
    },
    {
      "index": 148,
      "start_sec": 574.0,
      "end_sec": 576.0,
      "text": "A gente tem meio que duas gotas."
    },
    {
      "index": 149,
      "start_sec": 576.0,
      "end_sec": 579.0,
      "text": "E elas se linkam no músculo do..."
    },
    {
      "index": 150,
      "start_sec": 581.0,
      "end_sec": 584.0,
      "text": "Nos músculos do braço e do..."
    },
    {
      "index": 151,
      "start_sec": 584.0,
      "end_sec": 587.0,
      "text": "Do chest, do peito, do peitoral."
    },
    {
      "index": 152,
      "start_sec": 589.0,
      "end_sec": 592.0,
      "text": "É o que eu quis dizer com o formato de coração."
    },
    {
      "index": 153,
      "start_sec": 592.0,
      "end_sec": 595.0,
      "text": "Mas a gota também funciona."
    },
    {
      "index": 154,
      "start_sec": 595.0,
      "end_sec": 598.0,
      "text": "As partes separadas, então a gente pode ir."
    }
  ]
}