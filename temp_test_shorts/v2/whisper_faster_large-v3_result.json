    {
      "index": 148,
      "start_sec": 365.86,
      "end_sec": 366.86,
      "text": "Assim que eu parei"
    },
    {
      "index": 149,
      "start_sec": 366.86,
      "end_sec": 367.86,
      "text": "Foi talvez meio brusco"
    },
    {
      "index": 150,
      "start_sec": 367.86,
      "end_sec": 368.86,
      "text": "Eu tava tomando chá"
