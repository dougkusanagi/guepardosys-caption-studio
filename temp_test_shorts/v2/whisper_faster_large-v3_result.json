    {
      "index": 145,
      "start_sec": 362.1,
      "end_sec": 363.86,
      "text": "O café também te vicia, né"
    },
    {
      "index": 146,
      "start_sec": 363.86,
      "end_sec": 364.86,
      "text": "É óbvio"
    },
    {
      "index": 147,
      "start_sec": 364.86,
      "end_sec": 365.86,
      "text": "E ai eu"
